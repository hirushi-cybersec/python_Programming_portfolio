Item_name=input("enter the item name: ")
while True:
    try:
         Amount=float(input("enter the Amount: "))
         break
    except ValueError:
        print("Error: Add numbers only")
       
while True:
    Category=input("enter the category: ")
    if Category in ["food","travel","education","other"]:
         break
    else:
         print("only use food,travel,education,other for categories")

with open("expenses.txt", "a") as f:
    f.write(f"{Item_name},{Amount},{Category}\n")
    print("saved")
   
